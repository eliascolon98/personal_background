{
  "name": "consulta-antecedentes-policia",
  "version": "1.0.0",
  "description": "Consulta automatizada de antecedentes judiciales en la Policía Nacional de Colombia",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
